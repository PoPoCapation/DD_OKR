<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.bugstack.infrastructure.dao.IOkrTaskUserDao">

    <resultMap id="BaseResultMap" type="cn.bugstack.infrastructure.dao.po.OkrTaskUserPO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="task_id" property="taskId"/>
        <result column="createtime" property="createtime"/>
        <result column="updatetime" property="updatetime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, task_id, createtime, updatetime
    </sql>

    <insert id="insert" parameterType="cn.bugstack.infrastructure.dao.po.OkrTaskUserPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO okr_task_user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="taskId != null">task_id,</if>
        </trim>
        <trim prefix="VALUES(" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="taskId != null">#{taskId},</if>
        </trim>
    </insert>

    <select id="queryById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM okr_task_user
        WHERE id = #{id}
    </select>

    <update id="update" parameterType="cn.bugstack.infrastructure.dao.po.OkrTaskUserPO">
        UPDATE okr_task_user
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="taskId != null">task_id = #{taskId},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM okr_task_user WHERE id = #{id}
    </delete>

    <select id="queryUserIdsByTaskId" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT user_id FROM okr_task_user WHERE task_id = #{taskId}
    </select>

    <delete id="deleteByTaskId" parameterType="java.lang.Long">
        DELETE FROM okr_task_user WHERE task_id = #{taskId}
    </delete>

    <select id="queryTaskIdsByUserId" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT task_id FROM okr_task_user WHERE user_id = #{userId}
    </select>

    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO okr_task_user (user_id, task_id) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.taskId})
        </foreach>
    </insert>

</mapper>
